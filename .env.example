# URL base do Supabase (sem /rest/v1/)
SUPABASE_URL=https://seu-projeto.supabase.co

# Secret key — apenas Netlify Functions / netlify dev (não vai no bundle do React)
SUPABASE_SECRET_KEY=sua_secret_key

# Opcional: URL do netlify dev quando o React roda em :3000 e as functions em :8888
REACT_APP_NETLIFY_DEV_URL=http://localhost:8888
